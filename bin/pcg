#!/usr/bin/env perl
use v5.36;
use Encode qw(decode);
use App::PerlGraph::CLI;

# Human I/O is UTF-8: encode output (source bodies and identifiers come back from
# the graph as decoded characters) so non-ASCII isn't mojibake or a "Wide
# character in print" warning, and decode args so non-ASCII symbol names match
# the stored graph. (`pcg serve` re-asserts raw bytes on its own handles -- it
# does its own UTF-8 via the JSON-RPC codec.)
binmode STDOUT, ':encoding(UTF-8)';
binmode STDERR, ':encoding(UTF-8)';
@ARGV = map { decode('UTF-8', $_) } @ARGV;

exit App::PerlGraph::CLI->run(@ARGV);

__END__

=head1 NAME

pcg - Perl code knowledge graph for AI agents

=head1 SYNOPSIS

    pcg index [--runtime] [--jobs N] [--max-file-size SZ] [path]   build / refresh the graph
                                              (--max-file-size 1M skips huge generated-data files)
    pcg sync  [--runtime] [path]      incremental update
    pcg watch [--interval N] [--poll] [path]  re-index on change (inotify on Linux, else poll)
    pcg explore <query> [path]        symbols + source + relationships, in one call
    pcg node    <symbol> [path]       a symbol's source + callers/callees
    pcg search  <query>  [path]       symbol search (locations)
    pcg callers|callees|impact <symbol> [path]
    pcg path <A> <B> [path]           shortest call path from A to B
    pcg affected [--tests] [--stdin] [--path DIR] <files>
    pcg unused [--all] [path]         dead-code candidates
    pcg export [--format dot|mermaid|json] [--around SYM] [--depth N] [path]
    pcg status  [path]                node/edge/provenance counts
    pcg serve   --mcp [--watch] [path]   run the MCP server (stdio JSON-RPC)
    pcg install | uninstall           (de)register the MCP server with Claude Code

=head1 DESCRIPTION

See L<App::PerlGraph>.

=cut
